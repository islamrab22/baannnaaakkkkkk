# ==========================================
# DATABASE (PostgreSQL / Supabase)
# ==========================================
# App runtime connection. On Supabase this is the "Transaction pooler"
# (Supavisor/PgBouncer, port 6543) connection string.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bankdb?schema=public"

# Used ONLY by Prisma CLI (migrate deploy/dev) — must be a DIRECT
# (non-pooled) connection. On Supabase this is the "Direct connection"
# string on port 5432, NOT the pooler URL. If DATABASE_URL and DIRECT_URL
# point at a transaction-mode pooler, `prisma migrate deploy` will hang
# indefinitely trying to acquire its advisory lock — see README.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/bankdb?schema=public"

# ==========================================
# SERVER
# ==========================================
NODE_ENV="development"
PORT=3000
CLIENT_URL="http://localhost:3000"

# ==========================================
# AUTHENTICATION (JWT)
# ==========================================
JWT_ACCESS_SECRET="change-me-to-a-long-random-string"
JWT_REFRESH_SECRET="change-me-to-a-different-long-random-string"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
COOKIE_SECRET="change-me-cookie-secret"

# ==========================================
# CLOUDINARY (Image Uploads)
# ==========================================
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ==========================================
# TELEGRAM NOTIFICATIONS (optional)
# ==========================================
# Sends a Telegram message for every admin action (create/update/delete/
# login, from the audit log) and every customer submission (contact form,
# loan request, card request). Leave both blank to disable — notifications
# are skipped silently, nothing else is affected.
#
# Setup: message @BotFather on Telegram, run /newbot to get a bot token.
# Message your new bot (or add it to a group), then call
# https://api.telegram.org/bot<TOKEN>/getUpdates to find your chat_id.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# ==========================================
# SEED (optional overrides for prisma/seed.ts)
# ==========================================
SEED_ADMIN_PASSWORD="Admin@12345"
SEED_EDITOR_PASSWORD="Editor@12345"
SEED_VIEWER_PASSWORD="Viewer@12345"

# ==========================================
# LEGACY (Gemini AI assistant widget, unrelated to CMS)
# ==========================================
GEMINI_API_KEY="MY_GEMINI_API_KEY"
APP_URL="http://localhost:3000"
